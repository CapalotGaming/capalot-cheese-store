# Server
PORT=3000
PUBLIC_FRONTEND_URL=http://localhost:5500

# Supabase
SUPABASE_URL=https://ggdsqwzbjyxcixfysjhc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Square webhook verification
# Square Dashboard -> Webhooks -> your endpoint -> Signature key
SQUARE_WEBHOOK_SIGNATURE_KEY=PASTE_SQUARE_WEBHOOK_SIGNATURE_KEY_HERE
# This must exactly match the public webhook URL you enter in Square.
# Localhost will not work for Square webhooks unless you use a tunnel like ngrok.
SQUARE_WEBHOOK_URL=https://your-live-backend-domain.com/webhooks/square
